{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account profile for StudyMate AI",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Normalized email address"
        },
        "username": {
          "type": "string",
          "description": "Public display name"
        },
        "avatar": {
          "type": "string",
          "description": "Selected avatar identifier"
        },
        "level": {
          "type": "integer",
          "description": "User progression level"
        },
        "badge": {
          "type": "string",
          "description": "User earned badge or title"
        },
        "joinDate": {
          "type": "string",
          "description": "ISO timestamp of registration"
        },
        "country": {
          "type": "string",
          "description": "User country of origin"
        },
        "violationsCount": {
          "type": "integer",
          "description": "Total count of community chat violations"
        },
        "muteExpiresAt": {
          "type": "string",
          "description": "ISO timestamp when the user's chat mute ends, if any"
        },
        "isBanned": {
          "type": "boolean",
          "description": "True if the user is suspended from the app"
        },
        "banReason": {
          "type": "string",
          "description": "Reason for suspension"
        },
        "passwordHash": {
          "type": "string",
          "description": "PBKDF2 password hash"
        },
        "passwordSalt": {
          "type": "string",
          "description": "PBKDF2 salt"
        }
      },
      "required": ["email", "username", "avatar", "level"]
    },
    "Message": {
      "title": "Message",
      "description": "StudyMate community chat message",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "level": {
          "type": "integer"
        },
        "badge": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "repliedToId": {
          "type": "string"
        },
        "repliedToUser": {
          "type": "string"
        },
        "isDeleted": {
          "type": "boolean"
        },
        "deletedBy": {
          "type": "string"
        },
        "reportsCount": {
          "type": "integer"
        }
      },
      "required": ["id", "userEmail", "username", "text", "timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "Chat abuse report created by users",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "messageId": {
          "type": "string"
        },
        "messageText": {
          "type": "string"
        },
        "messageAuthor": {
          "type": "string"
        },
        "reportedBy": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed"]
        },
        "actionTaken": {
          "type": "string"
        },
        "reviewedAt": {
          "type": "string"
        }
      },
      "required": ["id", "messageId", "messageAuthor", "reportedBy", "reason", "timestamp", "status"]
    },
    "AdminLog": {
      "title": "AdminLog",
      "description": "Audit trail log of administrative actions",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "adminEmail": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "targetEmail": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["id", "adminEmail", "action", "details", "timestamp"]
    },
    "SyncData": {
      "title": "SyncData",
      "description": "User synchronized data including planner, tasks, alarms, timetable, and habits",
      "type": "object",
      "properties": {
        "profile": {
          "type": "object"
        },
        "tasks": {
          "type": "array"
        },
        "alarms": {
          "type": "array"
        },
        "timetable": {
          "type": "array"
        },
        "habits": {
          "type": "array"
        },
        "badges": {
          "type": "array"
        },
        "activityLog": {
          "type": "array"
        },
        "notifications": {
          "type": "array"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["updatedAt"]
    },
    "AIRequestLog": {
      "title": "AIRequestLog",
      "description": "Telemetry request log for AI responses",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "responseTimeMs": {
          "type": "integer"
        },
        "success": {
          "type": "boolean"
        },
        "error": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["id", "provider", "endpoint", "responseTimeMs", "success", "timestamp"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "User",
      "description": "Stores user profiles indexed by normalized email"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Community chat messages"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Moderation reports for inappropriate chat messages"
    },
    "/adminLogs/{logId}": {
      "schema": "AdminLog",
      "description": "Administrative actions audit trail"
    },
    "/syncData/{email}": {
      "schema": "SyncData",
      "description": "Encrypted or structured user backups (Planner, habits, calendar, and performance metrics)"
    },
    "/aiRequestLogs/{logId}": {
      "schema": "AIRequestLog",
      "description": "AI request performance logs"
    }
  }
}
